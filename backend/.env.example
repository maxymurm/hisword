APP_NAME=HisWord
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database (PostgreSQL) ──────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=hisword
DB_USERNAME=hisword
DB_PASSWORD=secret

# ── Session ────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Broadcasting / Queue / Cache ───────────────────
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=hisword_

# ── Redis ──────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail ───────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@hisword.app"
MAIL_FROM_NAME="${APP_NAME}"

# ── AWS / S3 / R2 ─────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=hisword
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Meilisearch ───────────────────────────────────
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=masterKey
SCOUT_DRIVER=meilisearch
SCOUT_QUEUE=true

# ── Laravel Reverb (WebSocket) ────────────────────
REVERB_APP_ID=hisword
REVERB_APP_KEY=hisword-key
REVERB_APP_SECRET=hisword-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

# ── Sanctum ───────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost:5173,localhost:8000

# ── Bible / Modules ──────────────────────────────
BIBLE_DEFAULT_MODULE=KJV
BIBLE_MODULE_DISK=local
BIBLE_MODULE_PATH=sword-modules

# ── Bintex / YES2 Modules ────────────────────────
BINTEX_MODULE_DISK=local
BINTEX_MODULE_PATH=bintex-modules
BINTEX_CATALOG_URL=https://api.hisword.app/catalog

# ── Sync Engine ──────────────────────────────────
SYNC_CONFLICT_STRATEGY=lww
SYNC_MAX_BATCH_SIZE=500
SYNC_RATE_LIMIT=100
SYNC_MAX_DEVICES=10

# ── Frontend ─────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
