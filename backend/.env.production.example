# ────────────────────────────────────────────────────────────────
# HisWord — PRODUCTION Environment Configuration
# ────────────────────────────────────────────────────────────────
# Copy this file to .env on your production server and fill in
# the secret values. NEVER commit a filled .env to version control.
# ────────────────────────────────────────────────────────────────

APP_NAME=HisWord
APP_ENV=production
APP_KEY=                        # php artisan key:generate
APP_DEBUG=false
APP_URL=https://hisword.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ── Database (PostgreSQL) ──────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=hisword
DB_USERNAME=                    # Use a dedicated DB user, not postgres
DB_PASSWORD=                    # Strong random password

# ── Session ────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.hisword.app
SESSION_SECURE_COOKIE=true

# ── Broadcasting / Queue / Cache ───────────────────
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=hisword_

# ── Redis ──────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=                 # Set a Redis password
REDIS_PORT=6379

# ── Mail ───────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=                      # smtp.mailgun.org, etc
MAIL_PORT=587
MAIL_USERNAME=                  # SMTP credentials
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@hisword.app"
MAIL_FROM_NAME="${APP_NAME}"

# ── AWS / S3 / R2 ─────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=hisword
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Meilisearch ───────────────────────────────────
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=                # Generate a strong key
SCOUT_DRIVER=meilisearch
SCOUT_QUEUE=true

# ── Laravel Reverb (WebSocket) ────────────────────
REVERB_APP_ID=hisword
REVERB_APP_KEY=                 # Generate: openssl rand -hex 16
REVERB_APP_SECRET=              # Generate: openssl rand -hex 32
REVERB_HOST=ws.hisword.app
REVERB_PORT=443
REVERB_SCHEME=https

# ── Sanctum ───────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=hisword.app,www.hisword.app

# ── Bible / Modules ──────────────────────────────
BIBLE_DEFAULT_MODULE=KJV
BIBLE_MODULE_DISK=local
BIBLE_MODULE_PATH=sword-modules

# ── Bintex / YES2 Modules ────────────────────────
BINTEX_MODULE_DISK=local
BINTEX_MODULE_PATH=bintex-modules
BINTEX_CATALOG_URL=https://api.hisword.app/catalog

# ── Sync Engine ──────────────────────────────────
SYNC_CONFLICT_STRATEGY=lww
SYNC_MAX_BATCH_SIZE=500
SYNC_RATE_LIMIT=100
SYNC_MAX_DEVICES=10

# ── Sentry ───────────────────────────────────────
SENTRY_LARAVEL_DSN=             # https://xxxxx@oXXXX.ingest.sentry.io/XXXX
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ── Frontend ─────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
VITE_SENTRY_DSN=                # Frontend Sentry DSN (can be same or different)
